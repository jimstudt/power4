menu "Power4"

    config POWER4_RELAY_COUNT
        int "Number of relay outputs"
        default 6
        range 1 32
        help
            Number of relay outputs managed by the relay manager task. The
            Waveshare ESP32-S3-Relay-6CH has six relay outputs.

    config POWER4_RELAY_GPIO_MAP
        string "Relay GPIO map"
        default "1,2,41,42,45,46"
        help
            Comma-separated GPIO numbers for relay channels, in relay order.
            For the Waveshare ESP32-S3-Relay-6CH, CH1..CH6 are GPIO
            1, 2, 41, 42, 45, and 46.

    config POWER4_RELAY_ACTIVE_LEVEL
        int "Relay active GPIO level"
        default 1
        range 0 1
        help
            GPIO level that energizes a relay. Use 1 for active-high relay
            drivers and 0 for active-low relay drivers.

    config POWER4_POLICY_PERIOD_SECONDS
        int "Policy evaluation period, seconds"
        default 60
        range 1 3600
        help
            Period between policy evaluations. The operational default is one
            minute.

    config POWER4_POLICY_TASK_STACK_BYTES
        int "Policy task stack size, bytes"
        default 16384
        range 4096 65536
        help
            Stack allocated for the policy task. Lua creates and tears down an
            interpreter each cycle, so this is intentionally larger than the
            simple relay and console support tasks.

    config POWER4_POLICY_TASK_PRIORITY
        int "Policy task priority"
        default 4
        range 1 24
        help
            FreeRTOS priority for the policy task.

    config POWER4_MAX_BATTERIES
        int "Maximum tracked batteries"
        default 16
        range 1 64
        help
            Maximum number of named batteries kept in the in-memory battery
            observation table. When a new battery is observed and the table is
            full, the least recently seen battery is evicted.

    config POWER4_MAX_BANKS
        int "Maximum configured battery banks"
        default 4
        range 1 16
        help
            Maximum number of named battery banks stored in NVS. Keeping this
            small bounds the persistent configuration blob and the temporary
            memory needed to edit it.

    config POWER4_BATTERY_SCAN_PERIOD_SECONDS
        int "BLE battery scan period, seconds"
        default 60
        range 10 3600
        help
            Period between BLE scans for battery management systems.

    config POWER4_BATTERY_SCAN_DURATION_SECONDS
        int "BLE battery scan duration, seconds"
        default 10
        range 1 60
        help
            Duration of each BLE scan window for battery management systems.

endmenu
